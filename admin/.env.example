PORT=8080
HOST=localhost
LOG_LEVEL=info
APP_KEY=some_random_key
NODE_ENV=development
SESSION_DRIVER=cookie
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_DATABASE=babylon
DB_PASSWORD=password
DB_SSL=false
REDIS_HOST=localhost
REDIS_PORT=6379
# Storage path for Babylon content (ZIM files, maps, etc.)
# On Windows dev, use an absolute path like: C:/babylon-storage
# On Linux production, use: /opt/babylon/storage
BABYLON_STORAGE_PATH=/opt/babylon/storage